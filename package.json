{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:admin": "vite --config vite.admin.config.js --port ${VITE_ADMIN_PORT:-5173}",
        "dev:app": "vite --config vite.config.js --port ${VITE_PORT:-5174}",
        "build:app": "vite build --config vite.config.js",
        "build:admin": "vite build --config vite.admin.config.js",
        "dev": "npm run dev:admin & npm run dev:app",
        "build": "npm run build:app && npm run build:admin",
        "prepare": "husky",
        "release": "release-it --ci --git.tagExclude='*[-]*'",
        "release:major": "release-it major --ci --git.tagExclude='*[-]*'",
        "release:minor": "release-it minor --ci --git.tagExclude='*[-]*'",
        "release:pr": "release-it --ci --preRelease=pr --no-plugins.@release-it/conventional-changelog",
        "release:pr:major": "release-it major --ci --preRelease=pr --no-plugins.@release-it/conventional-changelog",
        "release:pr:minor": "release-it minor --ci --preRelease=pr --no-plugins.@release-it/conventional-changelog"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@release-it/bumper": "^7.0.5",
        "@release-it/conventional-changelog": "^10.0.6",
        "@tailwindcss/vite": "^4.2.1",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "husky": "^9.1.7",
        "laravel-echo": "^2.3.1",
        "laravel-vite-plugin": "^2.0.0",
        "pusher-js": "^8.4.0",
        "release-it": "^19.2.4",
        "tailwindcss": "^4.2.1",
        "vite": "^7.0.7"
    }
}
