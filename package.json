{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:admin": "vite --config vite.admin.config.js",
        "dev:app": "vite --config vite.config.js",
        "build:app": "vite build --config vite.config.js",
        "build:admin": "vite build --config vite.admin.config.js",
        "dev": "npm run dev:admin & npm run dev:app",
        "build": "npm run build:app && npm run build:admin"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.1",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-echo": "^2.3.1",
        "laravel-vite-plugin": "^2.0.0",
        "pusher-js": "^8.4.0",
        "tailwindcss": "^4.2.1",
        "vite": "^7.0.7"
    }
}
